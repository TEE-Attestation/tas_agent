[Unit]
Description=TAS Agent LUKS Askpass Directory Watch
DefaultDependencies=no
Before=cryptsetup-pre.target
Wants=cryptsetup-pre.target

[Path]
DirectoryNotEmpty=/run/systemd/ask-password
MakeDirectory=yes

[Install]
WantedBy=cryptsetup.target
